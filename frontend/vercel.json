{
  "buildCommand": "CI=false yarn build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pointer-personalized-accomplished-springs.trycloudflare.com/api/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "https://pointer-personalized-accomplished-springs.trycloudflare.com/files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
