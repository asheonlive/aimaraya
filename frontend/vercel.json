{
  "buildCommand": "CI=false yarn build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aimaraya-backend.vercel.app/api/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "https://aimaraya-backend.vercel.app/files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
