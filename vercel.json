{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && CI=false yarn build",
  "installCommand": "cd frontend && yarn install --network-timeout 600000",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "excludeFiles": "{frontend/**,deploy/**,memory/**,test_reports/**,_QUARANTINE_REVIEW_DELETE_ME/**,backend/tests/**,aimaraya-web/**,*.md}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
