# Copy this file to deploy/backend.env and fill in real values.
# Never commit the real backend.env file to git.

# --- Required ---
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=aimaraya
JWT_SECRET=replace-with-a-long-random-string
EMERGENT_LLM_KEY=your-emergent-llm-key
STRIPE_API_KEY=sk_live_or_test_your_stripe_key

# --- Comfy Cloud (sole generation engine - your own real, paid account) ---
COMFY_API_KEY=
COMFY_BASE_URL=https://cloud.comfy.org
COMFY_EMAIL=
COMFY_PASSWORD=
COMFY_FIREBASE_API_KEY=

# --- CORS ---
# Comma-separated list of the real frontend origin(s). No trailing slashes.
CORS_ORIGINS=https://aimaraya-web.vercel.app
