# Copy to /etc/nginx/sites-available/aimaraya-api and symlink into sites-enabled.
# Replace api.YOUR_DOMAIN.com with your real backend subdomain.
# Run BEFORE certbot as a plain HTTP server; certbot --nginx will add the
# HTTPS server block and redirect automatically.

server {
    listen 80;
    server_name api.YOUR_DOMAIN.com;

    client_max_body_size 20M;

    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 660s;   # generation jobs can run several minutes
        proxy_send_timeout 660s;
    }
}
